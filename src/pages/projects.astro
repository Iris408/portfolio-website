---
// EN: /projects page — mounts ProjectsPageClient for the full React-controlled grid and modal
// JP: /projects ページ — React 制御のグリッドとモーダルを持つ ProjectsPageClient をマウントする

import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.jsx";
import Footer from "../components/Footer.jsx";
import ProjectsPageClient from "../components/ProjectsPageClient.jsx";
---

<MainLayout>
  <Navbar client:load />

  <main class="min-h-screen px-6 py-32">
    <section class="max-w-6xl mx-auto">

      <div class="text-center mb-14">
        <p class="font-avantgarde-book text-white text-4xl font-semibold mb-3">Portfolio</p>
        <h1 class="font-avantgarde-book text-5xl text-white font-bold">All Projects</h1>
        <p class="font-avantgarde-book text-white text-2xl mt-4 max-w-2xl mx-auto">
          A collection of backend, DevOps, full-stack, automation, and learning projects.
        </p>
      </div>

      {/* EN: ProjectsPageClient owns the grid and modal — client:load hydrates it as React */}
      {/* JP: ProjectsPageClient がグリッドとモーダルを管理 — client:load で React としてハイドレートされる */}
      <ProjectsPageClient client:load />

    </section>
  </main>

  <Footer />
</MainLayout>