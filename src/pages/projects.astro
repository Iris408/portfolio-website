---
// EN: /projects page — mounts ProjectsPageClient for the full React-controlled grid and modal
// JP: /projects ページ — React 制御のグリッドとモーダルを持つ ProjectsPageClient をマウントする

import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.jsx";
import Footer from "../components/Footer.jsx";
import ProjectsPageClient from "../components/ProjectsPageClient.jsx";
---

<MainLayout>
  <Navbar client:load />

  <main class="min-h-screen px-6 pb-28 pt-36">
    <section class="mx-auto max-w-6xl">
      <p class="mb-6 font-mono text-xs uppercase tracking-[0.35em] text-[#A5B5A3]">
        § Projects / Portfolio
      </p>

      <h1 class="mb-8 max-w-4xl text-4xl font-light leading-tight text-slate-100 md:text-5xl">
        Practical backend, full-stack, DevOps, and accessible product projects.
      </h1>

      <p class="mb-14 max-w-3xl text-base font-light leading-8 text-[#D8E0DD]">
        A collection of projects focused on API design, authentication, database
        persistence, deployment workflows, monitoring tools, accessible interfaces,
        and engineering documentation.
      </p>

      <ProjectsPageClient client:load />
    </section>
  </main> 

  <Footer />
</MainLayout>